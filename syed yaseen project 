#include <iostream>
using namespace std;

class Person
{
protected:
    string name;

public:
    void inputPerson()
    {
        cout << "Enter Name: ";
        cin >> name;
    }

    void displayPerson()
    {
        cout << "Name: " << name << endl;
    }

    virtual void checkCompatibility() = 0;
};

class BloodGroup : public Person
{
protected:
    string donor, receiver;

public:

    void input()
    {
        inputPerson();

        cout << "Enter Donor Blood Group: ";
        cin >> donor;

        cout << "Enter Receiver Blood Group: ";
        cin >> receiver;
    }

    bool isValid(string bg)
    {
        string valid[8] = {"O-","O+","A-","A+","B-","B+","AB-","AB+"};

        for(int i = 0; i < 8; i++)
        {
            if(bg == valid[i])
                return true;
        }
        return false;
    }

    void checkCompatibility() override
    {
        try
        {
            if(!isValid(donor))
                throw donor;

            if(!isValid(receiver))
                throw receiver;

            if(
                donor == "O-" ||

                (donor == "O+" &&
                (receiver=="O+"||receiver=="A+"||receiver=="B+"||receiver=="AB+")) ||

                (donor == "A-" &&
                (receiver=="A-"||receiver=="A+"||receiver=="AB-"||receiver=="AB+")) ||

                (donor == "A+" &&
                (receiver=="A+"||receiver=="AB+")) ||

                (donor == "B+" &&
                (receiver=="B+"||receiver=="AB+")) ||

                (donor == "AB+" &&
                receiver=="AB+")
            )
            {
                cout << "Compatible Blood Group" << endl;
            }
            else
            {
                cout << "Not Compatible Blood Group" << endl;
            }
        }
        catch(string error)
        {
            cout << "Exception Caught!" << endl;
            cout << "Invalid Blood Group: " << error << endl;
        }
    }
};

int main()
{
    BloodGroup bg;

    bg.input();
    bg.displayPerson();
    bg.checkCompatibility();

    return 0;
}